{
  "manifest_version": 3,
  "name": "OmniSuite — Sales Command Center",
  "version": "1.0.0",
  "description": "Unified sales CRM: Instantly.ai lead sync across all sub-accounts, AI copy personalization, live call coaching, and analytics.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://zoom.us/*",
    "https://app.zoom.us/*",
    "https://api.openai.com/*",
    "https://*.supabase.co/*"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "extension/background.js"
  },
  "action": {
    "default_popup": "extension/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://zoom.us/*",
        "https://app.zoom.us/*"
      ],
      "js": ["extension/content.js"],
      "css": ["extension/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
